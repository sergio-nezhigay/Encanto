    "reviews_slider_dame_i4PDnN": {
      "type": "reviews-slider-dame",
      "blocks": {
        "review_Bpy6qE": {
          "type": "review",
          "settings": {
            "show_stars": true,
            "rating": 5,
            "review_text": "<p>High quality tweezers and gel! Everything is wonderful. The products work perfectly together and I'm very satisfied with my purchase.</p>",
            "author_name": "Sophie M."
          }
        },
        "review_RGrMxM": {
          "type": "review",
          "settings": {
            "show_stars": true,
            "rating": 5,
            "review_text": "<p>I'm absolutely in love with the Enigma eyeshadow palette! The quality is outstanding - the shadows are incredibly pigmented and blend like a dream. The colors are so vibrant and true to pan, they really pop on the eyes. </p>",
            "author_name": "Alessandra T."
          }
        },
        "review_8yweRM": {
          "type": "review",
          "settings": {
            "show_stars": true,
            "rating": 5,
            "review_text": "<p>This powder is amazing! It covers redness perfectly and gives a beautiful matte effect. My skin looks flawless all day long. Highly recommend!</p>",
            "author_name": "Tisha G."
          }
        },
        "review_i7fJwy": {
          "type": "review",
          "settings": {
            "show_stars": true,
            "rating": 5,
            "review_text": "<p>A wonderful set of brushes! The quality is top notch—the bristles are soft, dense, and don't fall out even after repeated use. The brushes ensure even application of the product without streaks or smudges. The makeup turns out flawless! I am very happy with my purchase and recommend it to everyone!</p>",
            "author_name": "Amanda J."
          }
        },
        "review_LaReRw": {
          "type": "review",
          "settings": {
            "show_stars": true,
            "rating": 5,
            "review_text": "<p>Convenient to use, perfect for blondes, long-lasting. The TAUPE color pencil is easy to apply and stays put all day. As a blonde, this shade is exactly what I needed - it looks natural and complements my hair color beautifully. Highly recommend!</p>",
            "author_name": "Sara M."
          }
        },
        "review_dQEGr9": {
          "type": "review",
          "settings": {
            "show_stars": true,
            "rating": 5,
            "review_text": "<p>Beautiful colors, versatile for different makeup looks, blends beautifully. The VINTAGE eyeshadow palette has such gorgeous shades! I can create so many different makeup looks - from natural to dramatic. The shadows blend seamlessly and the color payoff is amazing. Love it!</p>",
            "author_name": "Kate W."
          }
        }
      },
      "block_order": [
        "review_Bpy6qE",
        "review_RGrMxM",
        "review_8yweRM",
        "review_i7fJwy",
        "review_LaReRw",
