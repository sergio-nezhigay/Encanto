{%- liquid
  assign product_url = product.url | prepend: request.origin
  assign group_id = product_url | append: '#product-group'
  assign organization_id = shop.url | append: '/#organization'
  assign brand_name = product.vendor | default: shop.name
  assign currency_code = cart.currency.iso_code | default: shop.currency
  assign price_valid_until = 'now' | date: '%Y-%m-%d' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d'
  assign shipping_policy_url = ''
  if shop.shipping_policy and shop.shipping_policy.url != blank
    assign shipping_policy_url = shop.shipping_policy.url | prepend: request.origin
  endif
  assign refund_policy_url = ''
  if shop.refund_policy and shop.refund_policy.url != blank
    assign refund_policy_url = shop.refund_policy.url | prepend: request.origin
  endif
  assign destination_country = localization.country.iso_code | default: shop.address.country_code
  assign review_rating_value = product.metafields.reviews.rating.value.rating | default: product.metafields.reviews.rating.value
  assign review_best_rating = product.metafields.reviews.rating.value.scale_max | default: 5
  assign review_count = product.metafields.reviews.rating_count

  assign reviews_data = product.metafields.reviews.reviews.value
  assign product_description_plain = product.description | strip_html | strip_newlines | replace: '&amp;', '&' | replace: '&#38;', '&' | strip
-%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProductGroup",
    "@id": {{ group_id | json }},
    "productGroupID": {{ product.id | json }},
    "name": {{ product.title | strip | json }},
    "description": {{ product_description_plain | json }},
    "url": {{ product_url | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ brand_name | json }}
    },
    "image": [
      {%- for image in product.images limit: 10 -%}
        {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    "offers": {
      "@type": "AggregateOffer",
      "url": {{ product_url | json }},
      "priceCurrency": {{ currency_code | json }},
      "lowPrice": {{ product.price_min | divided_by: 100.0 | json }},
      "highPrice": {{ product.price_max | divided_by: 100.0 | json }},
      "offerCount": {{ product.variants.size | json }}
    }{%- unless product.has_only_default_variant -%},
    "variesBy": [
      {%- for option_name in product.options -%}
        {%- assign option_name_downcase = option_name | downcase -%}
        {%- if option_name_downcase contains 'size' -%}
          "https://schema.org/size"
        {%- elsif option_name_downcase contains 'color' or option_name_downcase contains 'colour' -%}
          "https://schema.org/color"
        {%- elsif option_name_downcase contains 'material' -%}
          "https://schema.org/material"
        {%- elsif option_name_downcase contains 'pattern' -%}
          "https://schema.org/pattern"
        {%- else -%}
          {{ option_name | json }}
        {%- endif -%}{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
    {%- endunless -%},
    "hasVariant": [
      {%- for variant in product.variants -%}
        {%- liquid
          assign variant_image = variant.featured_media.preview_image | default: product.featured_media.preview_image | default: product.images.first
          assign option1_name = product.options_with_values[0].name | downcase
          assign option2_name = product.options_with_values[1].name | downcase
          assign option3_name = product.options_with_values[2].name | downcase
          assign option1_name_normalized = option1_name | replace: 'colour', 'color'
          assign option2_name_normalized = option2_name | replace: 'colour', 'color'
          assign option3_name_normalized = option3_name | replace: 'colour', 'color'
          assign option1_value = variant.options[0]
          assign option2_value = variant.options[1]
          assign option3_value = variant.options[2]
        -%}
        {
          "@type": "Product",
          "@id": {{ variant.url | prepend: request.origin | append: '#variant-' | append: variant.id | json }},
          "name": {%- if variant.title != 'Default Title' and variant.title != blank -%}{{ product.title | append: ' - ' | append: variant.title | strip | json }}{%- else -%}{{ product.title | strip | json }}{%- endif -%},
          "description": {{ product_description_plain | json }},
          "url": {{ variant.url | prepend: request.origin | json }},
          "isVariantOf": {
            "@id": {{ group_id | json }}
          }{%- if variant.sku != blank -%},
          "sku": {{ variant.sku | json }}
          {%- endif -%}{%- if variant.barcode != blank -%},
          "gtin": {{ variant.barcode | json }}
          {%- endif -%}{%- if variant_image != blank -%},
          "image": {{ variant_image | image_url: width: 1200 | prepend: 'https:' | json }}
          {%- endif -%}
          {%- if option1_value != blank and option1_name contains 'size' -%},
          "size": {{ option1_value | json }}
          {%- elsif option2_value != blank and option2_name contains 'size' -%},
          "size": {{ option2_value | json }}
          {%- elsif option3_value != blank and option3_name contains 'size' -%},
          "size": {{ option3_value | json }}
          {%- endif -%}
          {%- if option1_value != blank and option1_name_normalized contains 'color' -%},
          "color": {{ option1_value | json }}
          {%- elsif option2_value != blank and option2_name_normalized contains 'color' -%},
          "color": {{ option2_value | json }}
          {%- elsif option3_value != blank and option3_name_normalized contains 'color' -%},
          "color": {{ option3_value | json }}
          {%- endif -%}
          {%- if option1_value != blank and option1_name contains 'material' -%},
          "material": {{ option1_value | json }}
          {%- elsif option2_value != blank and option2_name contains 'material' -%},
          "material": {{ option2_value | json }}
          {%- elsif option3_value != blank and option3_name contains 'material' -%},
          "material": {{ option3_value | json }}
          {%- endif -%}
          {%- if option1_value != blank and option1_name contains 'pattern' -%},
          "pattern": {{ option1_value | json }}
          {%- elsif option2_value != blank and option2_name contains 'pattern' -%},
          "pattern": {{ option2_value | json }}
          {%- elsif option3_value != blank and option3_name contains 'pattern' -%},
          "pattern": {{ option3_value | json }}
          {%- endif -%}{%- unless product.has_only_default_variant -%},
          "additionalProperty": [
            {%- for option_name in product.options -%}
              {
                "@type": "PropertyValue",
                "name": {{ option_name | json }},
                "value": {{ variant.options[forloop.index0] | json }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
          {%- endunless -%},
          "offers": {
            "@type": "Offer",
            "url": {{ variant.url | prepend: request.origin | json }},
            "priceCurrency": {{ currency_code | json }},
            "price": {{ variant.price | divided_by: 100.0 | json }},
            "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
            "itemCondition": "https://schema.org/NewCondition",
            "priceValidUntil": {{ price_valid_until | json }},
            "seller": {
              "@id": {{ organization_id | json }}
            }
            {%- if shipping_policy_url != blank -%},
            "shippingDetails": {
              "@type": "OfferShippingDetails",
              "shippingSettingsLink": {{ shipping_policy_url | json }},
              "shippingRate": {
                "@type": "MonetaryAmount",
                "value": "0",
                "currency": {{ currency_code | json }}
              },
              "deliveryTime": {
                "@type": "ShippingDeliveryTime",
                "handlingTime": {
                  "@type": "QuantitativeValue",
                  "minValue": 0,
                  "maxValue": 1,
                  "unitCode": "DAY"
                },
                "transitTime": {
                  "@type": "QuantitativeValue",
                  "minValue": 3,
                  "maxValue": 7,
                  "unitCode": "DAY"
                }
              }
              {%- if destination_country != blank -%},
              "shippingDestination": {
                "@type": "DefinedRegion",
                "addressCountry": {{ destination_country | json }}
              }
              {%- endif -%}
            }
            {%- endif -%}
            {%- if refund_policy_url != blank -%},
            "hasMerchantReturnPolicy": {
              "@type": "MerchantReturnPolicy",
              "applicableCountry": {{ destination_country | default: 'ES' | json }},
              "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
              "returnFees": "https://schema.org/ReturnShippingFees",
              "returnShippingFeesAmount": {
                "@type": "MonetaryAmount",
                "value": "1",
                "currency": {{ currency_code | json }}
              },
              "returnMethod": "https://schema.org/ReturnByMail",
              "merchantReturnDays": 30,
              "merchantReturnLink": {{ refund_policy_url | json }}
            }
            {%- endif -%}
          }
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]{%- if review_rating_value != blank and review_count != blank and review_count > 0 -%},
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": {{ review_rating_value | json }},
      "bestRating": {{ review_best_rating | json }},
      "worstRating": "1",
      "ratingCount": {{ review_count | json }}
    }
    {%- endif -%}
    {%- if reviews_data != blank -%},
    "review": [
      {%- for review in reviews_data limit: 10 -%}
        {%- assign review_author = review.author | default: review.reviewer_name | default: review.name -%}
        {%- assign review_body = review.body | default: review.content | default: review.review -%}
        {%- assign review_value = review.rating | default: review.score -%}
        {
          "@type": "Review",
          {%- if review_author != blank -%}
          "author": {
            "@type": "Person",
            "name": {{ review_author | json }}
          },
          {%- endif -%}
          {%- if review_body != blank -%}
          "reviewBody": {{ review_body | strip_html | strip_newlines | json }},
          {%- endif -%}
          {%- if review_value != blank -%}
          "reviewRating": {
            "@type": "Rating",
            "ratingValue": {{ review_value | json }},
            "bestRating": {{ review_best_rating | json }},
            "worstRating": "1"
          }
          {%- else -%}
          "name": {{ product.title | append: ' review' | json }}
          {%- endif -%}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
    {%- endif -%}
  }
</script>
