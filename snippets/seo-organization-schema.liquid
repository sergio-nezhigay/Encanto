{%- liquid
  assign _links = ''
  if settings.social_twitter_link != blank
    assign _links = _links | append: settings.social_twitter_link | append: '||'
  endif
  if settings.social_facebook_link != blank
    assign _links = _links | append: settings.social_facebook_link | append: '||'
  endif
  if settings.social_pinterest_link != blank
    assign _links = _links | append: settings.social_pinterest_link | append: '||'
  endif
  if settings.social_instagram_link != blank
    assign _links = _links | append: settings.social_instagram_link | append: '||'
  endif
  if settings.social_tiktok_link != blank
    assign _links = _links | append: settings.social_tiktok_link | append: '||'
  endif
  if settings.social_tumblr_link != blank
    assign _links = _links | append: settings.social_tumblr_link | append: '||'
  endif
  if settings.social_snapchat_link != blank
    assign _links = _links | append: settings.social_snapchat_link | append: '||'
  endif
  if settings.social_youtube_link != blank
    assign _links = _links | append: settings.social_youtube_link | append: '||'
  endif
  if settings.social_vimeo_link != blank
    assign _links = _links | append: settings.social_vimeo_link | append: '||'
  endif
  assign same_as_items = _links | split: '||'

  assign search_target = shop.url | append: routes.search_url | append: '?q={search_term_string}'

  assign webpage_type = 'WebPage'
  if request.page_type == 'collection' or request.page_type == 'list-collections'
    assign webpage_type = 'CollectionPage'
  elsif request.page_type == 'product'
    assign webpage_type = 'ItemPage'
  elsif request.page_type == 'search'
    assign webpage_type = 'SearchResultsPage'
  endif

  assign webpage_date_published = ''
  assign webpage_date_modified = ''
  if request.page_type == 'article'
    assign webpage_date_published = article.published_at | date: '%Y-%m-%dT%H:%M:%SZ'
    assign webpage_date_modified = article.published_at | date: '%Y-%m-%dT%H:%M:%SZ'
  elsif request.page_type == 'product'
    assign webpage_date_published = product.published_at | date: '%Y-%m-%dT%H:%M:%SZ'
    assign webpage_date_modified = product.published_at | date: '%Y-%m-%dT%H:%M:%SZ'
  endif
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": {{ shop.url | append: '/#organization' | json }},
      "name": {{ shop.name | json }},
      "url": {{ shop.url | json }},
      "brand": {
        "@type": "Brand",
        "name": "CTR"
      },
      {%- if settings.logo %}
      "logo": {
        "@type": "ImageObject",
        "url": {{ settings.logo | image_url: width: 500 | prepend: 'https:' | json }},
        "width": 500
      },
      {%- endif %}
      {%- if shop.address.country_code != blank %}
      "address": {
        "@type": "PostalAddress",
        "addressCountry": {{ shop.address.country_code | json }}
      },
      {%- endif %}
      {%- if shop.email != blank or shop.phone != blank %}
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer service"
        {%- if shop.email != blank %},
        "email": {{ shop.email | json }}
        {%- endif %}
        {%- if shop.phone != blank %},
        "telephone": {{ shop.phone | json }}
        {%- endif %}
      },
      {%- endif %}
      "sameAs": [
        {%- for link in same_as_items %}
          {{ link | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor %}
      ]
    },
    {
      "@type": "WebSite",
      "@id": {{ shop.url | append: '/#website' | json }},
      "url": {{ shop.url | json }},
      "name": {{ shop.name | json }},
      "publisher": { "@id": {{ shop.url | append: '/#organization' | json }} },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": {{ search_target | json }}
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": {{ webpage_type | json }},
      "@id": {{ canonical_url | append: '#webpage' | json }},
      "url": {{ canonical_url | json }},
      "name": {{ page_title | json }},
      {%- if page_description != blank %}
      "description": {{ page_description | json }},
      {%- endif %}
      {%- if webpage_date_published != blank %}
      "datePublished": {{ webpage_date_published | json }},
      "dateModified": {{ webpage_date_modified | json }},
      {%- endif %}
      {%- if request.page_type == 'index' %}
      "about": { "@id": {{ shop.url | append: '/#organization' | json }} },
      {%- endif %}
      "isPartOf": { "@id": {{ shop.url | append: '/#website' | json }} }
    }
  ]
}
</script>
