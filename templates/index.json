    "ss_simple_faq_bmfLRg": {
      "type": "ss-simple-faq",
      "blocks": {
        "text_rmRMFc": {
          "type": "text",
          "settings": {
            "heading": "Are CTR products suitable for professional makeup artists?",
            "answer": "<p>Yes. CTR products are developed for precision, durability, and repeatable performance in professional artist workflows.</p>"
          }
        },
        "text_H734cm": {
          "type": "text",
          "settings": {
            "heading": "Where are CTR products manufactured?",
            "answer": "<p>CTR maintains in-house production oversight to support controlled craftsmanship, quality consistency, and professional-grade standards.</p>"
          }
        },
        "text_aUB4ch": {
          "type": "text",
          "settings": {
            "heading": "Do you ship internationally?",
            "answer": "<p>Yes. CTR serves customers and professional partners across more than 30 countries.</p>"
          }
        },
        "text_NhaQPV": {
          "type": "text",
          "settings": {
            "heading": "How can I contact customer support?",
            "answer": "<p>You can reach our support team directly through the contact form on the website for any product, order, or general inquiries.</p>"
          }
        },
        "text_6A4dCy": {
          "type": "text",
          "settings": {
            "heading": "What types of bristles do CTR brushes use?",
            "answer": "<p>CTR offers natural and synthetic options. Natural brushes use goat hair, squirrel hair, fox bristles, and bull hair. Synthetic brushes use Taklon and nylon fibers, ideal for cream and liquid products.</p>"
          }
        },
        "text_QakdRm": {
          "type": "text",
          "settings": {
            "heading": "How do I clean my makeup brushes?",
            "answer": "<p>Rinse bristles under lukewarm water with a gentle cleanser. Work into a lather, rinse well, reshape, and lay flat to dry. Avoid soaking the ferrule as it can loosen the glue over time.</p>"
          }
        },
        "text_Xr7qQN": {
          "type": "text",
          "settings": {
            "heading": "Are CTR products cruelty-free?",
            "answer": "<p>All CTR products are certified and produced under controlled quality standards. For specific cruelty-free or vegan queries, please reach out through our contact page.</p>"
          }
        },
        "text_RKfkXE": {
          "type": "text",
          "settings": {
            "heading": "What is the delivery time to EU countries?",
            "answer": "<p>Most EU orders arrive within 5 to 10 business days. Timelines vary by country and shipping method. Full details are available in our shipping policy at checkout.</p>"
          }
        },
        "text_9xWkFH": {
          "type": "text",
          "settings": {
            "heading": "What is your return policy?",
            "answer": "<p>We accept returns on unused, unopened products. If you receive a damaged or incorrect item, please contact us through the website with your order details and we will resolve it promptly.</p>"
          }
        },
        "text_n9HaTG": {
          "type": "text",
          "settings": {
            "heading": "Do you offer professional or bulk orders?",
            "answer": "<p>Yes. CTR supports professional artists and training centers with volume orders. For bulk pricing, please get in touch through our contact page.</p>"
          }
        },
        "text_AhBqGT": {
          "type": "text",
          "settings": {
            "heading": "What payment methods are accepted?",
            "answer": "<p>We accept Visa, Mastercard, American Express, PayPal, Apple Pay, Google Pay, Shop Pay, Maestro, Bancontact, and Union Pay, all processed securely at checkout.</p>"
          }
        }
      },
