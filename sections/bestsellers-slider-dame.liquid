    #bestsellers-{{ section.id }} .dame-header-actions {
      display: none;
    }
    #bestsellers-{{ section.id }} .dame-footer-actions {
      display: flex;
      justify-content: center;
      margin-top: 2px;
      padding-left: max(var(--dame-bestsellers-padding-left-mobile), 16px);
      padding-right: max(var(--dame-bestsellers-padding-right-mobile), 16px);
    }
  }

  #bestsellers-{{ section.id }} .dame-bestsellers-subtitle {
    font-size: var(--dame-bestsellers-subtitle-size-desktop);
    color: var(--dame-bestsellers-subtitle-color);
    margin: 0;
    font-weight: {{ section.settings.subtitle_font_weight }};
    letter-spacing: 0.2px;
  }

  #bestsellers-{{ section.id }} .dame-slider-container {
    position: relative;
    overflow: visible;
    width: 100%;
  }

  #bestsellers-{{ section.id }} .dame-products-slider {
    display: grid;
    grid-auto-flow: column;
    grid-auto-rows: auto;
    grid-auto-columns: {{ section.settings.card_width }}px;
    column-gap: 18px;
    row-gap: 0;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 20px;
    padding-left: 8px;
  }

  @media screen and (min-width: 750px) {
    #bestsellers-{{ section.id }} .dame-products-slider {
      padding-left: max(calc((100vw - 1456px) / 2 + 90px), 90px);
      padding-right: 0;
    }
  }

  @media screen and (max-width: 749px) {
    #bestsellers-{{ section.id }} .dame-slider-container {
        padding-left: 0;
        padding-right: 0;

  }
    #bestsellers-{{ section.id }} .dame-products-slider {
      padding-left: max(var(--dame-bestsellers-padding-left-mobile), 16px);
      padding-right: max(var(--dame-bestsellers-padding-right-mobile), 16px);
    }
  }

  #bestsellers-{{ section.id }} .dame-products-slider::-webkit-scrollbar {
    display: none;
  }

  /* CSS variable overrides for dame-product-card — apply section settings */
  #bestsellers-{{ section.id }} {
    --dame-card-image-height: {{ section.settings.product_image_height }}px;
    --dame-card-image-height-mobile: {{ section.settings.product_image_height_mobile }}px;
    --dame-card-product-name-color: {{ section.settings.product_name_color }};
    --dame-card-product-name-size: {{ section.settings.product_name_size_desktop }}px;
    --dame-card-product-name-size-mobile: {{ section.settings.product_name_size_mobile }}px;
    --dame-card-product-name-font-weight: {{ section.settings.product_name_font_weight }};
    --dame-card-discount-badge-bg: {{ section.settings.discount_badge_bg | default: "#FF4444" }};
    --dame-card-discount-badge-color: {{ section.settings.discount_badge_color | default: "#ffffff" }};
    --dame-card-stars-color: {{ section.settings.stars_color | default: "#FFD700" }};
    --dame-card-reviews-color: {{ section.settings.reviews_text_color | default: "#666666" }};
    --dame-card-sale-price-color: {{ section.settings.price_sale_color | default: "#D32F2F" }};
    --dame-card-original-price-color: {{ section.settings.price_original_color | default: "#999999" }};
  }

  /* Slider-specific card layout — width handled by grid-auto-columns above */

  #bestsellers-{{ section.id }} .dame-slider-progress {
    width: calc(100% - max(var(--dame-bestsellers-padding-left-desktop), 20px) - max(var(--dame-bestsellers-padding-right-desktop), 20px));
    height: 6px;
    background-color: {{ section.settings.progress_bg_color | default: "#E8E8E8" }};
    margin-top: 8px;
    margin-left: max(var(--dame-bestsellers-padding-left-desktop), 20px);
    margin-right: max(var(--dame-bestsellers-padding-right-desktop), 20px);
    border-radius: 3px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    #bestsellers-{{ section.id }} .dame-slider-progress {
      margin-left: max(calc((100vw - 1456px) / 2 + 90px), 90px);
      margin-right: max(calc((100vw - 1456px) / 2 + 82px), 82px);
      width: auto;
    }
  }

  @media screen and (max-width: 749px) {
    #bestsellers-{{ section.id }} .dame-slider-progress {
      display: none;
    }
  }

  #bestsellers-{{ section.id }} .dame-slider-progress-bar {
    display: block;
    height: 100%;
    background-color: {{ section.settings.progress_bar_color }};
    width: 0%;
    transition: width 0.3s ease;
    border-radius: 3px;
  }

  #bestsellers-{{ section.id }} .dame-slider-arrow {
    background: {{ section.settings.arrow_bg_color | default: "#F5F5F5" }};
    border: 1px solid {{ section.settings.arrow_border_color | default: "#E0E0E0" }};
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s;
    color: {{ section.settings.arrow_color | default: "#333333" }};
    flex-shrink: 0;
  }

  #bestsellers-{{ section.id }} .dame-slider-arrow:hover {
    background: {{ section.settings.arrow_hover_bg_color | default: "#E0E0E0" }};
    border-color: {{ section.settings.arrow_hover_border_color | default: "#CCCCCC" }};
    transform: scale(1.05);
    color: #ffffff;
  }

  #bestsellers-{{ section.id }} .dame-slider-arrow:hover svg {
    color: #ffffff;
  }

  #bestsellers-{{ section.id }} .dame-slider-arrow:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  @media screen and (max-width: 749px) {
    #bestsellers-{{ section.id }} .dame-bestsellers-title {
      font-size: 32px;
    }

    #bestsellers-{{ section.id }} .dame-bestsellers-subtitle {
      font-size: var(--dame-bestsellers-subtitle-size-mobile);
    }

    #bestsellers-{{ section.id }} .dame-bestsellers-header-content {
      flex-direction: column;
      align-items: flex-start;
    }

    #bestsellers-{{ section.id }} .dame-header-actions {
      margin-left: 0;
      justify-content: flex-start;
      gap: 0;
      width: 100%;
    }

    #bestsellers-{{ section.id }} .dame-product-card {
      flex: 0 0 {{ section.settings.card_width_mobile }}px;
      padding: 0px;
    }

    #bestsellers-{{ section.id }} .dame-slider-arrow {
      display: none;
    }
