  }

  #bestsellers-{{ section.id }} .dame-see-all-btn:hover {
    background-color: {{ section.settings.see_all_hover_bg_color }};
    color: {{ section.settings.see_all_hover_text_color }};
  }

  #bestsellers-{{ section.id }} .dame-footer-actions {
    display: none;
  }

