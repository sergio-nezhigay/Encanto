{%- assign shown_count = 0 -%}
{%- if section.settings.collection != blank -%}
  {%- assign bs_collection = collections[section.settings.collection] -%}
  {%- assign shown_count = section.settings.products_to_show -%}
  {%- if bs_collection.products.size < shown_count -%}
    {%- assign shown_count = bs_collection.products.size -%}
  {%- endif -%}
{%- endif -%}

<div
  id="bestsellers-{{ section.id }}"
  class="bestsellers-slider-wrapper {% if section.settings.custom_classes %}{{ section.settings.custom_classes }}{% endif %}"
>
  <section class="dame-bestsellers-section">
    <div class="page-width dame-bestsellers-header">
      <div class="dame-bestsellers-header-content">
        {% if section.settings.section_title != blank %}
          <h2 class="dame-bestsellers-title">{{ section.settings.section_title }}</h2>
        {% endif %}

        <div class="dame-header-actions">
          {% if section.settings.show_navigation_arrows and shown_count > 4 %}
            <div class="dame-slider-nav-buttons">
              <button class="dame-slider-arrow dame-slider-prev" aria-label="Previous slide">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <button class="dame-slider-arrow dame-slider-next" aria-label="Next slide">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          {% endif %}

          {% if section.settings.show_view_all and section.settings.button_text != blank %}
            <a href="{{ section.settings.button_url }}" class="dame-see-all-btn">
              {{ section.settings.button_text }}
            </a>
          {% endif %}
        </div>
      </div>

      {% if section.settings.section_subtitle != blank %}
        <div class="dame-bestsellers-subtitle">{{ section.settings.section_subtitle }}</div>
      {% endif %}
    </div>

    {% if section.settings.collection != blank %}
      {% assign collection = collections[section.settings.collection] %}

      {% if collection.products.size > 0 %}
        {%- assign shown_count = section.settings.products_to_show -%}
        {%- if collection.products.size < shown_count -%}
          {%- assign shown_count = collection.products.size -%}
        {%- endif -%}
        <div class="dame-slider-container">
          <div class="dame-products-slider" id="productsSlider-{{ section.id }}">
            {% for product in collection.products limit: section.settings.products_to_show %}
              {% render 'dame-product-card',
                product: product,
                add_to_cart_text: section.settings.add_to_cart_text,
                sold_out_text: section.settings.sold_out_text
              %}
            {% endfor %}
          </div>

          {% if section.settings.show_progress_bar and shown_count > 4 %}
            <div class="dame-slider-progress">
              <div class="dame-slider-progress-bar"></div>
            </div>
          {% endif %}
        </div>

        {% if section.settings.show_view_all and section.settings.button_text != blank %}
          <div class="page-width dame-footer-actions">
            <a href="{{ section.settings.button_url }}" class="dame-see-all-btn">
              {{ section.settings.button_text }}
            </a>
          </div>
        {% endif %}
      {% endif %}
    {% endif %}
  </section>
</div>

<style>
