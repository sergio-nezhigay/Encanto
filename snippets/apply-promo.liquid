<script>
(function() {
  var params = new URLSearchParams(window.location.search);
  var discount = params.get('discount');
  if (discount) {
    // Сохраняем промокод в sessionStorage
    sessionStorage.setItem('promo_code', discount);

    // Редирект на страницу применения промокода
    window.location.href = '/discount/' + encodeURIComponent(discount) + '?redirect=' + encodeURIComponent(window.location.pathname + window.location.search);
  }
})();
</script>